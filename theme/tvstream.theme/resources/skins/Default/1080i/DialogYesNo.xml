<?xml version="1.0" encoding="UTF-8"?>
<!-- DialogYesNo / DialogConfirm -->
<window>
  <type>dialog</type>
  <zorder>90</zorder>
  <defaultcontrol always="true">11</defaultcontrol>
  <controls>

    <!-- Full background dim -->
    <control type="image">
      <left>0</left><top>0</top>
      <width>1280</width><height>720</height>
      <texture colordiffuse="$COLOR[bg_dim]">white.png</texture>
    </control>

    <!-- Dialog box -->
    <control type="group">
      <left>340</left><top>240</top>
      <width>600</width><height>240</height>

      <control type="image">
        <left>0</left><top>0</top>
        <width>600</width><height>240</height>
        <texture colordiffuse="$COLOR[bg_elevated]">white.png</texture>
      </control>
      <control type="image">
        <left>0</left><top>0</top>
        <width>600</width><height>3</height>
        <texture colordiffuse="$COLOR[accent_cyan]">white.png</texture>
      </control>

      <!-- Heading (id=1) -->
      <control type="label" id="1">
        <left>20</left><top>16</top>
        <width>560</width><height>30</height>
        <font>fontBold20</font>
        <textcolor>$COLOR[text_primary]</textcolor>
        <label></label>
        <align>center</align>
      </control>

      <!-- Separator -->
      <control type="image">
        <left>20</left><top>52</top>
        <width>560</width><height>1</height>
        <texture colordiffuse="$COLOR[separator]">white.png</texture>
      </control>

      <!-- Message line 1 (id=2) -->
      <control type="label" id="2">
        <left>20</left><top>62</top>
        <width>560</width><height>50</height>
        <font>font16</font>
        <textcolor>$COLOR[text_secondary]</textcolor>
        <label></label>
        <align>center</align><aligny>center</aligny>
        <scroll>true</scroll>
      </control>

      <!-- Message line 2 (id=3) -->
      <control type="label" id="3">
        <left>20</left><top>114</top>
        <width>560</width><height>30</height>
        <font>font14</font>
        <textcolor>$COLOR[text_muted]</textcolor>
        <label></label>
        <align>center</align>
      </control>

      <!-- NO button (id=10) -->
      <control type="button" id="10">
        <left>20</left><top>185</top>
        <width>260</width><height>40</height>
        <label>Ne</label>
        <font>fontBold16</font>
        <align>center</align><aligny>center</aligny>
        <textcolor>$COLOR[text_primary]</textcolor>
        <focusedcolor>$COLOR[text_primary]</focusedcolor>
        <texturefocus colordiffuse="$COLOR[btn_save]">white.png</texturefocus>
        <texturenofocus colordiffuse="$COLOR[bg_surface]">white.png</texturenofocus>
      </control>

      <!-- YES button (id=11) -->
      <control type="button" id="11">
        <left>320</left><top>185</top>
        <width>260</width><height>40</height>
        <label>Ano</label>
        <font>fontBold16</font>
        <align>center</align><aligny>center</aligny>
        <textcolor>$COLOR[btn_play_text]</textcolor>
        <focusedcolor>$COLOR[text_primary]</focusedcolor>
        <texturefocus colordiffuse="$COLOR[btn_focus]">white.png</texturefocus>
        <texturenofocus colordiffuse="$COLOR[btn_play]">white.png</texturenofocus>
      </control>

    </control>
  </controls>
</window>

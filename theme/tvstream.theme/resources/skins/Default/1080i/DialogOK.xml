<?xml version="1.0" encoding="UTF-8"?>
<!-- DialogOK -->
<window>
  <type>dialog</type>
  <zorder>90</zorder>
  <defaultcontrol always="true">10</defaultcontrol>
  <controls>

    <control type="image">
      <left>0</left><top>0</top>
      <width>1280</width><height>720</height>
      <texture colordiffuse="$COLOR[bg_dim]">white.png</texture>
    </control>

    <control type="group">
      <left>340</left><top>260</top>
      <width>600</width><height>200</height>

      <control type="image">
        <left>0</left><top>0</top>
        <width>600</width><height>200</height>
        <texture colordiffuse="$COLOR[bg_elevated]">white.png</texture>
      </control>
      <control type="image">
        <left>0</left><top>0</top>
        <width>600</width><height>3</height>
        <texture colordiffuse="$COLOR[accent_cyan]">white.png</texture>
      </control>

      <!-- Heading (id=1) -->
      <control type="label" id="1">
        <left>20</left><top>14</top>
        <width>560</width><height>30</height>
        <font>fontBold20</font>
        <textcolor>$COLOR[text_primary]</textcolor>
        <label></label>
        <align>center</align>
      </control>

      <control type="image">
        <left>20</left><top>50</top>
        <width>560</width><height>1</height>
        <texture colordiffuse="$COLOR[separator]">white.png</texture>
      </control>

      <!-- Message lines (id=2,3,4) -->
      <control type="label" id="2">
        <left>20</left><top>58</top>
        <width>560</width><height>30</height>
        <font>font16</font><textcolor>$COLOR[text_secondary]</textcolor>
        <label></label><align>center</align>
      </control>
      <control type="label" id="3">
        <left>20</left><top>88</top>
        <width>560</width><height>30</height>
        <font>font14</font><textcolor>$COLOR[text_muted]</textcolor>
        <label></label><align>center</align>
      </control>
      <control type="label" id="4">
        <left>20</left><top>118</top>
        <width>560</width><height>22</height>
        <font>font13</font><textcolor>$COLOR[text_muted]</textcolor>
        <label></label><align>center</align>
      </control>

      <!-- OK button (id=10) -->
      <control type="button" id="10">
        <left>200</left><top>148</top>
        <width>200</width><height>38</height>
        <label>OK</label>
        <font>fontBold16</font>
        <align>center</align><aligny>center</aligny>
        <textcolor>$COLOR[btn_play_text]</textcolor>
        <focusedcolor>$COLOR[text_primary]</focusedcolor>
        <texturefocus colordiffuse="$COLOR[btn_focus]">white.png</texturefocus>
        <texturenofocus colordiffuse="$COLOR[btn_play]">white.png</texturenofocus>
      </control>
    </control>

  </controls>
</window>

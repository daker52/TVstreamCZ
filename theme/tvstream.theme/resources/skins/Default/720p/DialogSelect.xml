<?xml version="1.0" encoding="UTF-8"?>
<!-- DialogSelect – list selection dialog -->
<window>
  <type>dialog</type>
  <zorder>90</zorder>
  <defaultcontrol always="true">3</defaultcontrol>
  <controls>

    <control type="image">
      <left>0</left><top>0</top>
      <width>1280</width><height>720</height>
      <texture colordiffuse="$COLOR[bg_dim]">white.png</texture>
    </control>

    <control type="group">
      <left>240</left><top>100</top>
      <width>800</width><height>520</height>

      <!-- Panel BG -->
      <control type="image">
        <left>0</left><top>0</top>
        <width>800</width><height>520</height>
        <texture colordiffuse="$COLOR[bg_elevated]">white.png</texture>
      </control>
      <control type="image">
        <left>0</left><top>0</top>
        <width>800</width><height>3</height>
        <texture colordiffuse="$COLOR[accent_cyan]">white.png</texture>
      </control>

      <!-- Heading (id=1) -->
      <control type="label" id="1">
        <left>20</left><top>12</top>
        <width>760</width><height>36</height>
        <font>fontBold20</font>
        <textcolor>$COLOR[text_primary]</textcolor>
        <label></label>
      </control>

      <control type="image">
        <left>20</left><top>52</top>
        <width>760</width><height>1</height>
        <texture colordiffuse="$COLOR[separator]">white.png</texture>
      </control>

      <!-- List (id=3) -->
      <control type="list" id="3">
        <left>0</left><top>56</top>
        <width>800</width><height>464</height>
        <itemheight>46</itemheight>
        <scrolltime>200</scrolltime>

        <itemlayout height="46">
          <!-- Hover highlight -->
          <control type="image">
            <left>0</left><top>0</top>
            <width>800</width><height>46</height>
            <texture colordiffuse="$COLOR[bg_surface]">white.png</texture>
            <visible>ListItem.IsSelected</visible>
          </control>
          <!-- Focus bar -->
          <control type="image">
            <left>0</left><top>0</top>
            <width>4</width><height>46</height>
            <texture colordiffuse="$COLOR[accent_cyan]">white.png</texture>
            <visible>ListItem.IsSelected</visible>
          </control>
          <!-- Item label -->
          <control type="label">
            <left>20</left><top>0</top>
            <width>760</width><height>46</height>
            <font>font16</font>
            <textcolor>$COLOR[text_primary]</textcolor>
            <selectedcolor>$COLOR[text_accent]</selectedcolor>
            <label>$INFO[ListItem.Label]</label>
            <aligny>center</aligny>
          </control>
        </itemlayout>

        <focusedlayout height="46">
          <control type="image">
            <left>0</left><top>0</top>
            <width>800</width><height>46</height>
            <texture colordiffuse="$COLOR[btn_focus_bg]">white.png</texture>
          </control>
          <control type="image">
            <left>0</left><top>0</top>
            <width>4</width><height>46</height>
            <texture colordiffuse="$COLOR[border_focus]">white.png</texture>
          </control>
          <control type="label">
            <left>20</left><top>0</top>
            <width>760</width><height>46</height>
            <font>fontBold16</font>
            <textcolor>$COLOR[text_accent]</textcolor>
            <label>$INFO[ListItem.Label]</label>
            <aligny>center</aligny>
          </control>
        </focusedlayout>

      </control>
    </control>

  </controls>
</window>
